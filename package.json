{
  "name": "shatr",
  "version": "1.0.0",
  "description": "Publish a fully-featured, fast, accessible Arabic-poem website from just the text — one shatr per line.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs",
    "preview": "node scripts/build.mjs && node -e \"const{spawn}=require('child_process');spawn('python3',['-m','http.server','8080'],{cwd:'dist',stdio:'inherit'})\"",
    "check": "node scripts/cli.mjs check",
    "init": "node scripts/cli.mjs init",
    "studio": "node scripts/cli.mjs studio"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  },
  "bin": {
    "shatr": "scripts/cli.mjs"
  }
}
